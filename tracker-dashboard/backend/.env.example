# Production roster/auth DB — READ-ONLY. Login + employee roster + PM-team scoping.
# The app only ever SELECTs from this DB; never writes/updates/deletes.
AUTH_DATABASE_URL=

# Telemetry DB (WorkWise Phase 2 rollups) — read for insights; audit rows written here.
TELEMETRY_DATABASE_URL=

# Secret for signing this app's own JWTs (independent of the portal's).
JWT_SECRET=change-me-to-a-long-random-string

# Real live-status window (matches the extension flush cadence).
OFFLINE_THRESHOLD_S=90

# LOCAL ONLY: honor the temp demo credentials below. Never set in prod.
ALLOW_DEV_LOGIN=1

# Temp demo credentials (admin is synthetic; PM resolves the real chirag.rao for scoping)
DEMO_ADMIN_EMAIL=admin@tracker.local
DEMO_ADMIN_PASSWORD=Admin@2026
DEMO_PM_EMAIL=pm@tracker.local
DEMO_PM_PASSWORD=Pm@2026